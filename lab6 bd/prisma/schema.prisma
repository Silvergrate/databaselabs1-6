generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model bot_command {
  command_id        Int                 @id @default(autoincrement())
  command_name      String              @unique @db.VarChar(50)
  description       String?
  is_active         Boolean             @default(true)
  command_execution command_execution[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bot_order {
  order_id      Int          @id @default(autoincrement())
  user_id       Int
  promo_code_id Int?
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  total_amount  Decimal      @default(0) @db.Decimal(10, 2)
  status_id     Int
  promo_code    promo_code?  @relation(fields: [promo_code_id], references: [promo_code_id], onUpdate: NoAction, map: "fk_bot_order_promo_code")
  order_status  order_status @relation(fields: [status_id], references: [status_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bot_order_status")
  bot_user      bot_user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bot_order_user")
  order_item    order_item[]
  payment       payment?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bot_user {
  user_id                                 Int                 @id @default(autoincrement())
  telegram_id                             BigInt              @unique
  username                                String              @unique @db.VarChar(50)
  role                                    String              @default("user") @db.VarChar(20)
  status                                  String              @default("active") @db.VarChar(20)
  registered_at                           DateTime            @default(now()) @db.Timestamp(6)
  balance                                 Decimal             @default(0) @db.Decimal(10, 2)
  bot_order                               bot_order[]
  command_execution                       command_execution[]
  publication                             publication[]
  referral_referral_referred_idTobot_user referral?           @relation("referral_referred_idTobot_user")
  referral_referral_referrer_idTobot_user referral[]          @relation("referral_referrer_idTobot_user")
  product_review                          product_review[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model command_execution {
  execution_id  Int         @id @default(autoincrement())
  user_id       Int
  command_id    Int
  executed_at   DateTime    @default(now()) @db.Timestamp(6)
  result_status String      @db.VarChar(20)
  bot_command   bot_command @relation(fields: [command_id], references: [command_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_command_execution_command")
  bot_user      bot_user    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_command_execution_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_item {
  order_item_id Int       @id @default(autoincrement())
  order_id      Int
  product_id    Int
  quantity      Int
  unit_price    Decimal   @db.Decimal(10, 2)
  line_total    Decimal   @db.Decimal(10, 2)
  bot_order     bot_order @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_item_order")
  product       product   @relation(fields: [product_id], references: [product_id], onUpdate: NoAction, map: "fk_order_item_product")

  @@unique([order_id, product_id], map: "uq_order_item_order_product")
}

model order_status {
  status_id Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(20)
  bot_order bot_order[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment {
  payment_id     Int            @id @default(autoincrement())
  order_id       Int            @unique
  amount         Decimal        @db.Decimal(10, 2)
  paid_at        DateTime?      @db.Timestamp(6)
  method_id      Int
  status_id      Int
  payment_method payment_method @relation(fields: [method_id], references: [method_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_method")
  bot_order      bot_order      @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_payment_order")
  payment_status payment_status @relation(fields: [status_id], references: [status_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_payment_status")
}

model payment_method {
  method_id Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(30)
  payment   payment[]
}

model payment_status {
  status_id Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(20)
  payment   payment[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product {
  product_id      Int              @id @default(autoincrement())
  name            String           @db.VarChar(100)
  price           Decimal          @db.Decimal(10, 2)
  is_active       Boolean          @default(true)
  product_type_id Int
  is_featured     Boolean          @default(false)
  sort_order      Int              @default(0)
  order_item      order_item[]
  product_type    product_type     @relation(fields: [product_type_id], references: [product_type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_product_product_type")
  product_review  product_review[]
}

model product_type {
  product_type_id Int       @id @default(autoincrement())
  name            String    @unique @db.VarChar(50)
  product         product[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model promo_code {
  promo_code_id  Int         @id @default(autoincrement())
  code           String      @unique @db.VarChar(50)
  discount_type  String      @db.VarChar(20)
  discount_value Decimal     @db.Decimal(10, 2)
  starts_at      DateTime    @db.Timestamp(6)
  ends_at        DateTime    @db.Timestamp(6)
  bot_order      bot_order[]
}

model publication {
  publication_id  Int               @id @default(autoincrement())
  author_id       Int
  title           String            @db.VarChar(150)
  content         String
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  bot_user        bot_user          @relation(fields: [author_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_publication_author")
  publication_tag publication_tag[]
}

model publication_tag {
  publication_id Int
  tag_id         Int
  publication    publication @relation(fields: [publication_id], references: [publication_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_publication_tag_publication")
  tag            tag         @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_publication_tag_tag")

  @@id([publication_id, tag_id], map: "pk_publication_tag")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model referral {
  referral_id                             Int      @id @default(autoincrement())
  referrer_id                             Int
  referred_id                             Int      @unique
  reward_amount                           Decimal  @default(0) @db.Decimal(10, 2)
  created_at                              DateTime @default(now()) @db.Timestamp(6)
  bot_user_referral_referred_idTobot_user bot_user @relation("referral_referred_idTobot_user", fields: [referred_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_referral_referred")
  bot_user_referral_referrer_idTobot_user bot_user @relation("referral_referrer_idTobot_user", fields: [referrer_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_referral_referrer")
}

model tag {
  tag_id          Int               @id @default(autoincrement())
  name            String            @unique @db.VarChar(50)
  publication_tag publication_tag[]
}

model product_review {
  review_id         Int      @id @default(autoincrement())
  product_id        Int
  user_id           Int
  rating            Int
  comment           String?
  created_at        DateTime @default(now()) @db.Timestamp(6)
  moderation_status String   @default("pending") @db.VarChar(20)

  product  product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  bot_user bot_user @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([product_id, user_id])
}
